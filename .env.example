# ============================================================
#  SEB-LEDGER CORE — Environment Configuration
#  The Pan-East African Informal Sector Economic Ledger
#  Intellectual Property: Alexander Eliud Letema, Letema Group
# ============================================================

# Local server port. Change to 3000 if 5173 is occupied.
PORT=3000

# Your Supabase Project URL — found in Project Settings > API
# Example: https://abcdefghijklmnop.supabase.co
SUPABASE_URL=https://your-project-ref.supabase.co

# Supabase Service Role Key — found in Project Settings > API > service_role
# WARNING: This key bypasses Row Level Security. Never expose it publicly.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Supabase Anon/Public Key (used for read-safe operations if needed)
SUPABASE_ANON_KEY=your-anon-key-here

# Set to "production" when deploying for real. Enables strict CORS origin
# checking and a startup warning if ADMIN_API_KEY is missing.
NODE_ENV=development

# Comma-separated list of browser origins allowed to call this API in
# production (e.g. https://app.sebledger.tz,https://admin.sebledger.tz).
# Ignored when NODE_ENV is not "production".
ALLOWED_ORIGINS=

# Optional shared secret required (via the X-Admin-Key header) to access
# GET /api/v1/governance/dashboard, which exposes ledger-wide financial
# aggregates. Strongly recommended for any non-local deployment — if left
# unset, the dashboard endpoint is open to anyone who can reach the API.
ADMIN_API_KEY=

